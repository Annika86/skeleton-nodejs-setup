{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "pretty": false,
    "target": "es2020",
    "module": "es2015",
    "moduleResolution": "bundler",
    "types": ["node"],
    "declaration": true,
    "declarationMap": false,
    "sourceMap": true,
    "inlineSources": false,
    "inlineSourceMap": false,
    "composite": false,
    "noEmitOnError": true,
    "strictNullChecks": false,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "strictPropertyInitialization": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "alwaysStrict": true,
    "preserveConstEnums": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
